<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP traffic for your API server -->
    <!-- Replace with your production server IP/domain -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">180.179.21.98</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">172.16.10.248</domain>
        <!-- Add your production domain here when ready -->
        <!-- <domain includeSubdomains="true">your-production-domain.com</domain> -->
    </domain-config>
    
    <!-- For HTTPS production servers, you can add base-config -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
